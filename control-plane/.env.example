# Required before exposing the admin service.
GALLERY_ADMIN_PASSWORD=replace-with-a-long-random-password
GALLERY_SESSION_SECRET=replace-with-at-least-32-random-characters
GALLERY_SECURE_COOKIE=true

# Existing gallery checkout mounted into the control-plane container.
GALLERY_REPO_ROOT=/workspace/gallery
GALLERY_DB_PATH=/data/gallery.db
GALLERY_SPOOL_PATH=/spool

# Prompt reversal and optional render-back verification.
OPENAI_API_KEY=
GALLERY_VISION_MODEL=gpt-5.5
GALLERY_IMAGE_MODEL=gpt-image-2
GALLERY_RENDER_BACK_ENABLED=false
GALLERY_FIDELITY_THRESHOLD=88

# Source APIs.
X_BEARER_TOKEN=
UNSPLASH_ACCESS_KEY=
WALLHAVEN_API_KEY=

# Publishing. Keep false until the server checkout has a GitHub deploy key.
GALLERY_GIT_PUSH=false
GALLERY_GIT_REMOTE=origin
GALLERY_GIT_BRANCH=main

# Daily schedule in Asia/Shanghai.
GALLERY_SCHEDULE_HOUR=9
GALLERY_SCHEDULE_MINUTE=30
